# R3 video pipeline — optional overrides (all have sane defaults, none are secrets)

# Demo stack
R3_URL=http://127.0.0.1:8080
R3_ADMIN_USER=admin
R3_ADMIN_PASS=demo-password-r3
R3_DB_PATH=./out/demo.db
R3_CONFIG_PATH=./out/referee-demo.toml
R3_BINARY=../target/release/rusty-rules-referee

# Publish (optional; requires ssh key auth to r3.pugbot.net)
R3_PUBLISH_HOST=r3.pugbot.net
R3_PUBLISH_USER=bcmx
R3_PUBLISH_PATH=/home/bcmx/domains/r3.pugbot.net/public_html/media
