{
  "name": "r3-video",
  "private": true,
  "version": "1.0.0",
  "description": "Automated demo video pipeline for the R3 web UI",
  "type": "module",
  "scripts": {
    "install:browsers": "playwright install chromium",
    "seed": "tsx seed/seed.ts",
    "stack:start": "tsx scripts/start-demo-stack.ts",
    "stack:stop": "tsx scripts/stop-demo-stack.ts",
    "record": "tsx record.ts",
    "narrate": "tsx narrate.ts",
    "build": "tsx build-video.ts",
    "publish": "tsx scripts/publish.ts",
    "video": "npm run seed && npm run record && npm run narrate && npm run build",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@playwright/test": "^1.48.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "fluent-ffmpeg": "^2.1.3",
    "msedge-tts": "^2.0.5",
    "playwright": "^1.48.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "wait-on": "^8.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/fluent-ffmpeg": "^2.1.26",
    "@types/node": "^22.7.0"
  }
}
